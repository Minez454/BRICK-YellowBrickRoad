{
  "name": "yellowbrickroad",
  "version": "1.0.0",
  "description": "YellowBrickRoad - Comprehensive case management system with BRICK AI Guide assessments and resource coordination",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build && cd .. && npm run build:sw",
    "build:sw": "node scripts/build-service-worker.js",
    "setup-database": "node scripts/setup-database.js",
    "seed-data": "node scripts/seed-data.js",
    "create-indexes": "node scripts/create-indexes.js",
    "setup-cron": "node scripts/setup-cron.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "docker:build": "docker build -t yellowbrickroad .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "deploy:staging": "git push origin staging",
    "deploy:production": "git push origin main"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "sharp": "^0.32.5",
    "socket.io": "^4.7.2",
    "twilio": "^4.15.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "case-management",
    "ai-assistant",
    "social-services",
    "homelessness",
    "resource-mapping"
  ],
  "author": "Briggs AI Guide Team",
  "license": "MIT"
}
